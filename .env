# ==============================================================================
# FORJINN-DESK OFFLINE CONFIGURATION (.env)
# ==============================================================================
# This configuration is optimized for completely air-gapped/offline deployments.
# It prioritizes local network endpoints and disables internet dependencies.

# ------------------------------------------------------------------------------
# FORJINN_DESK_* (Application Configuration)
# ------------------------------------------------------------------------------
# Restrict access to local origins
FORJINN_DESK_ALLOWED_ORIGINS="*"

# Remote accessibility on local network (Set to 'true' if accessed by peers)
FORJINN_DESK_ALLOW_REMOTE=false

# Auto-updates MUST be disabled in offline environments to prevent polling failures
FORJINN_DESK_DISABLE_AUTO_UPDATE=0

# Local developer tools
FORJINN_DESK_CDP_PORT=9222
FORJINN_DESK_HOST="127.0.0.1"
FORJINN_DESK_PORT=3000
FORJINN_DESK_REMOTE=false
FORJINN_DESK_MULTI_INSTANCE=0

# Application Paths (Defaults to app data directory if left empty)
# FORJINN_DESK_EXTENSIONS_PATH="/local/path/to/extensions"
# FORJINN_DESK_FONTS_DIR="/local/path/to/fonts"
# FORJINN_DESK_BUN_CACHE_DIR="/local/path/to/bun/cache"

# ------------------------------------------------------------------------------
# AI/API Keys & Local Inference Configuration
# ------------------------------------------------------------------------------
# NOTE: Since the project is offline, use your local model endpoints (e.g. Ollama, vLLM, LM Studio)

# --- OpenAI-Compatible Local Inference (e.g. Ollama on port 11434) ---
OPENAI_API_KEY="local-inference-key"
OPENAI_BASE_URL="http://101.53.140.44:8001/v1"


# --- Private Image Generation (e.g., local Stable Diffusion webui) ---
FORJINN_DESK_IMG_PLATFORM="openai" # Or custom provider mapped to local
FORJINN_DESK_IMG_BASE_URL="http://101.53.140.44:8003/v1"
FORJINN_DESK_IMG_API_KEY="local-img-key"
FORJINN_DESK_IMG_MODEL="GLM-Image/"

# ------------------------------------------------------------------------------
# Security & Auth Tokens
# ------------------------------------------------------------------------------
# Generate robust, random strings for offline state encryption
CSRF_SECRET="offline_csrf_protection_fallback_secret_replace_in_production"
JWT_SECRET="offline_jwt_authorization_fallback_secret_replace_in_production"

# ------------------------------------------------------------------------------
# Sentry (Error & Crash Reporting)
# ------------------------------------------------------------------------------
# Point to a private, local Sentry instance or leave empty to disable remote reporting
SENTRY_DSN=""
SENTRY_ENVIRONMENT="local-offline"
SENTRY_DEBUG=false

# ------------------------------------------------------------------------------
# Telemetry (OpenTelemetry)
# ------------------------------------------------------------------------------
# If you run a local telemetry collector (e.g., Jaeger, Prometheus, Zipkin)
# OTEL_EXPORTER_OTLP_ENDPOINT="http://127.0.0.1:4317"
# OTEL_SERVICE_NAME="forjinn-desk"

# ------------------------------------------------------------------------------
# MCP (Model Context Protocol) & Team Agents
# ------------------------------------------------------------------------------
FORJINN_MCP_PORT=8080
TEAM_MCP_PORT=8081
